# orion-cowork — Electron 桌機 chat app(本機 sidecar)。
#
# 複製成 `.env`,填 provider key(或走 proxy):
#   cp apps/orion-cowork/.env.example apps/orion-cowork/.env
#
# Cowork 是純桌機 app,沒 web auth / OAuth / Postgres / JWT — 那些都在 chat-api。

# ─── Provider keys — 二選一 ────────────────────────────────────────────────
# (A) 直連 — 在這裡填 key,sidecar 內 SDK 直接打 api.anthropic.com / openai.com。
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# (A2) OpenRouter — 一支 key 接 100+ models(各 vendor),含 :free tier 免費 model。
# https://openrouter.ai/keys 註冊 + 拿 key。
# OPENROUTER_API_KEY=sk-or-v1-xxxxx
# 可選 — OpenRouter dashboard 顯示用:
# ORION_OPENROUTER_REFERER=https://github.com/anthropics/orion-agent
# ORION_OPENROUTER_TITLE=Orion Cowork

# (A3) Google Gemini — Gemini OpenAI-compat endpoint。
# https://aistudio.google.com/apikey 拿 key。**跟 GOOGLE_STT_API_KEY 區隔** —
# STT / LLM 是不同 API,不要共用同一支 key。
# GEMINI_API_KEY=AIzaSyXxxxxx

# (B) 走 orion-model-proxy(集中管 key / cost / routing)。
# 設了下行,(A) 兩個 key 就不用填(在 proxy 那台機填)。
# ORION_MODEL_PROXY_URL=http://127.0.0.1:9090
#
# Phase 32:proxy 是 multi-tenant — admin 在 proxy `/admin/ui` 為**你**生一個
# token(`sk-orion-<env>-...`),貼到下面。SDK / audio call 自動帶 Authorization。
# 沒帶 / 格式錯 / 不在 DB → 401(對齊 OpenAI/Anthropic AuthenticationError);
# 已 revoked → 403(PermissionDenied);超 budget cap → 402。
# ORION_MODEL_PROXY_KEY=sk-orion-prod-...
#
# Phase 33-A 計費 attribution — proxy 端標哪台 Cowork。Cowork sidecar
# entrypoint 預設 `orion-cowork`,要覆蓋(多台桌機要區分)再設。
# ORION_CLIENT_ID=orion-cowork

# OLLAMA_HOST=localhost:11434

# ─── Google Cloud STT(可選,Cowork 語音輸入用)─────────────────────────────
# 沒設 → 用 OpenAI Whisper(走 OPENAI_API_KEY)。
# GOOGLE_STT_API_KEY=

# ─── Cowork 本機資料目錄(罕用)────────────────────────────────────────────
# 預設 ~/.orion/sessions/cowork.db + ~/.orion/blobs/ + ~/.orion/tts-cache/
# ORION_COWORK_DATA_DIR=~/.orion

# ─── SerpAPI(WebSearch tool 用,可選)────────────────────────────────────
# SERPAPI_API_KEY=

# ─── Output / Cache 調校(可選)──────────────────────────────────────────
# ORION_MAX_TOKENS_PER_TURN=32768
# ORION_CACHE_TTL_STATIC=1h
# ORION_CACHE_TTL_SESSION=1h
# ORION_CACHE_TTL_MESSAGES=5m
# ORION_WEBFETCH_TTL_SECONDS=300
# ORION_FILE_HISTORY_MAX_SNAPSHOTS=100
# ORION_MEMORY_RANKER=heuristic
# ORION_MEMORY_RANKER_MODEL=claude-haiku-4-5
# ORION_MODELS_FILE=/path/to/custom-models.json

# ─── Token storage(advanced)──────────────────────────────────────────────
# 預設 macOS Keychain;改 file backend:
# ORION_DISABLE_KEYCHAIN=1
# ORION_MASTER_KEY=
