{
  "name": "@orion/cowork",
  "private": true,
  "version": "0.1.0",
  "description": "Orion Cowork — PC desktop app (Electron + React),talks to orion-sdk via Python stdio sidecar。",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5174 && cross-env NODE_ENV=development electron-vite-runner",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron",
    "dist": "electron-builder --config electron-builder.yml",
    "dist:mac": "electron-builder --config electron-builder.yml --mac",
    "dist:win": "electron-builder --config electron-builder.yml --win",
    "dist:linux": "electron-builder --config electron-builder.yml --linux",
    "typecheck": "tsc --noEmit -p renderer/tsconfig.json && tsc --noEmit -p electron/tsconfig.json"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}
