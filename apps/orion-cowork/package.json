{
  "name": "@orion/cowork",
  "private": true,
  "version": "0.1.0",
  "description": "Orion Cowork — PC desktop app (Electron + React),talks to orion-sdk via Python stdio sidecar。",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5174 && tsc -p electron/tsconfig.json && bash scripts/dev-brand-electron.sh && cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:sidecar": "bash scripts/build-sidecar.sh",
    "build": "npm run build:renderer && npm run build:electron",
    "build:all": "npm run build:sidecar && npm run build",
    "dist": "npm run build:all && electron-builder --config electron-builder.yml",
    "dist:mac": "npm run build:all && electron-builder --config electron-builder.yml --mac",
    "dist:win": "npm run build:all && electron-builder --config electron-builder.yml --win",
    "dist:linux": "npm run build:all && electron-builder --config electron-builder.yml --linux",
    "typecheck": "tsc --noEmit -p renderer/tsconfig.json && tsc --noEmit -p electron/tsconfig.json",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}
