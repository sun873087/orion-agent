# orion-cli — 終端機 chat。
#
# 複製成 `.env`,填 provider key(或走 proxy):
#   cp apps/orion-cli/.env.example apps/orion-cli/.env

# ─── Provider keys — 二選一 ────────────────────────────────────────────────
# (A) 直連 OpenAI / Anthropic — 在這裡填 key。
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# (A2) OpenRouter — 一支 key 接 100+ models 來自各 vendor,含 :free tier 免費 model。
# OPENROUTER_API_KEY=sk-or-v1-xxxxx

# (A3) Google Gemini — Gemini OpenAI-compat endpoint。
# https://aistudio.google.com/apikey 拿 key。跟 GOOGLE_STT_API_KEY 區隔。
# GEMINI_API_KEY=AIzaSyXxxxxx

# (B) 走 orion-model-proxy(集中管 key / cost / routing)— 設這行,
#     上面兩個 key 就不用填(在 proxy 那台機填)。
# ORION_MODEL_PROXY_URL=http://127.0.0.1:9090
#
# Phase 32:proxy 是 multi-tenant — admin 在 proxy `/admin/ui` 為**你**生一個
# token(`sk-orion-<env>-...`),貼到下面。SDK / audio call 自動帶 Authorization。
# 沒帶 / 格式錯 / 不在 DB → 401(對齊 OpenAI/Anthropic AuthenticationError);
# 已 revoked → 403(PermissionDenied);超 budget cap → 402。
# ORION_MODEL_PROXY_KEY=sk-orion-prod-...
#
# Phase 33-A 計費 attribution — proxy `usage_log.client_id` 記錄請求來源,
# admin UI 看得出哪台機(CLI / chat-api / cowork)用多少。CLI entrypoint
# 預設 `orion-cli`,通常不必動,要覆蓋(e.g. CI 環境想標 `ci-runner`)再設。
# ORION_CLIENT_ID=orion-cli

# ─── Ollama(可選,本機 LLM) ──────────────────────────────────────────────
# 預設 localhost:11434,不用設。
# OLLAMA_HOST=localhost:11434

# ─── Model catalog override(罕用) ────────────────────────────────────────
# Default:packaged models.json。改 pricing / 加 model 時指外部 JSON。
# 設了 ORION_MODEL_PROXY_URL 後 catalog 走 proxy /v1/catalog,這個失效。
# ORION_MODELS_FILE=/path/to/custom-models.json

# ─── Output / Cache 調校(可選) ───────────────────────────────────────────
# 每輪 max output tokens(取 env 跟 model 上限的較小者)
# ORION_MAX_TOKENS_PER_TURN=32768

# Anthropic prompt cache TTL — "5m" / "1h"
# ORION_CACHE_TTL_STATIC=1h
# ORION_CACHE_TTL_SESSION=1h
# ORION_CACHE_TTL_MESSAGES=5m

# WebFetch URL cache 秒數(預設 300)
# ORION_WEBFETCH_TTL_SECONDS=300

# 每 session file-history snapshot 上限(預設 100,LRU 砍最舊)
# ORION_FILE_HISTORY_MAX_SNAPSHOTS=100

# ─── Memory ranker(注入 system prompt 用) ────────────────────────────────
# Modes:heuristic(預設,0 LLM)/ llm(送 Haiku 4.5 評分)
# ORION_MEMORY_RANKER=heuristic
# ORION_MEMORY_RANKER_MODEL=claude-haiku-4-5

# ─── SerpAPI(WebSearch tool 用) ──────────────────────────────────────────
# 沒設 → WebSearch tool 回錯,LLM fallback 用 WebFetch。
# SerpAPI key 在 https://serpapi.com/manage-api-key
# SERPAPI_API_KEY=

# ─── 資料目錄 / 密鑰儲存(罕用) ───────────────────────────────────────────
# CLI 預設用 ~/.orion/ 為 root。
# ORION_HOME=~/.orion

# Token 預設存 OS keychain;Linux server / Docker / CI 沒 keychain daemon 時
# 自動 fallback 到加密 file。強制走 file:
# ORION_DISABLE_KEYCHAIN=1
# 產生 master key:
#   uv run python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# ORION_MASTER_KEY=
