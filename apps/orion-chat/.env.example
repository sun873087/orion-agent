# orion-chat — FastAPI chat server(+ JWT auth + Postgres-ready)。
#
# 複製成 `.env`,填必要 key + DB / JWT:
#   cp apps/orion-chat/.env.example apps/orion-chat/.env

# ─── Provider keys — 二選一 ────────────────────────────────────────────────
# (A) 直連 — 在這裡填 key。
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# (B) 走 orion-model-proxy。
# ORION_MODEL_PROXY_URL=http://127.0.0.1:9090
#
# Phase 32:proxy 是 multi-tenant — admin 在 proxy `/admin/ui` 為**這台 chat-api
# 服務**生一個 token(`sk-orion-<env>-...`),貼到下面。SDK / audio call 自動帶
# Authorization。沒帶 / 格式錯 / 不在 DB → 401;已 revoked → 403;超 budget cap → 402。
# ORION_MODEL_PROXY_KEY=sk-orion-prod-...
#
# Phase 33-A 計費 attribution — proxy 端標哪台機。chat-api entrypoint 預設
# `orion-chat-api`,要覆蓋(production / staging 區分)再設。
# ORION_CLIENT_ID=orion-chat-api

# OLLAMA_HOST=localhost:11434

# ─── Default model(可選,user 沒選時用) ───────────────────────────────────
# ORION_PROVIDER=anthropic
# ORION_MODEL=claude-sonnet-4-6

# ─── Persistence(必要 — 不設走記憶體模式,重啟全清) ──────────────────────
# SQLite:
# ORION_DB_URL=sqlite+aiosqlite:///./orion.db
# Postgres:
# ORION_DB_URL=postgresql+asyncpg://user:pass@localhost/orion
#
# 啟動時自動跑 schema migration(預設 true)
# ORION_DB_AUTO_CREATE=true

# ─── JWT auth(必要 production)─────────────────────────────────────────────
# 簽 access token 的 secret。沒設 = 啟動時 random,重啟所有 token 失效。
# 產生一段穩定 random string 給生產:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# ORION_JWT_SECRET=change-me-to-a-long-random-string

# ─── CORS(production 必設)────────────────────────────────────────────────
# 預設 `*`(dev 用),production 改成 web 的 origin。
# ORION_CORS_ORIGINS=https://chat.example.com

# ─── OAuth providers(Settings → Connections 用)────────────────────────────
# 每 provider 兩個 env 都設了「Connect」按鈕才會亮。
# 註冊 OAuth app 時 callback URL 用:
#   http://localhost:8000/oauth/callback     (dev)
#   https://<your-domain>/oauth/callback     (production)

# GitHub — https://github.com/settings/developers → New OAuth App
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Linear — https://linear.app/settings/api/applications → New
# LINEAR_OAUTH_CLIENT_ID=
# LINEAR_OAUTH_CLIENT_SECRET=

# Google — https://console.cloud.google.com → APIs & Services → Credentials
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Microsoft — https://portal.azure.com → Microsoft Entra ID → App registrations
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=

# ─── SerpAPI(WebSearch tool 用,可選)────────────────────────────────────
# SERPAPI_API_KEY=

# ─── Output / Cache 調校(同 CLI,可選) ──────────────────────────────────
# ORION_MAX_TOKENS_PER_TURN=32768
# ORION_CACHE_TTL_STATIC=1h
# ORION_CACHE_TTL_SESSION=1h
# ORION_CACHE_TTL_MESSAGES=5m
# ORION_WEBFETCH_TTL_SECONDS=300
# ORION_FILE_HISTORY_MAX_SNAPSHOTS=100
# ORION_MEMORY_RANKER=heuristic
# ORION_MEMORY_RANKER_MODEL=claude-haiku-4-5
# ORION_MODELS_FILE=/path/to/custom-models.json

# ─── Token storage backend(advanced)──────────────────────────────────────
# 預設 OS keychain;Linux server / Docker 沒 daemon 自動 fallback file。
# 強制走 file:
# ORION_DISABLE_KEYCHAIN=1
# Production 用 secrets manager 注入 master key:
#   uv run python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# ORION_MASTER_KEY=
