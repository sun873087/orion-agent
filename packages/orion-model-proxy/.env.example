# orion-model-proxy — 只給跑 `make dev-model-proxy` 那台機看。
# Client(CLI / Chat / Cowork)不必看這份。
#
# 複製成 `.env`,填 upstream key:
#   cp packages/orion-model-proxy/.env.example packages/orion-model-proxy/.env

# ─── Upstream provider keys(必要) ─────────────────────────────────────────
# Proxy 收到 client request → 用這裡的真 key 覆寫 header 後 forward 到上游。
# 只設你會用的 provider。

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# OpenRouter — https://openrouter.ai/keys
# 一支 key 接 100+ models 來自各 vendor(含 :free tier)。Client 走 proxy 時
# base_url 自動切 `{proxy}/openrouter/v1`(對齊 openai 處理)。
# OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Google Gemini — https://aistudio.google.com/apikey
# Gemini OpenAI-compat endpoint。Client 走 proxy 時 base_url 自動切
# `{proxy}/google/v1`(同 openai/openrouter)。**跟 GOOGLE_STT_API_KEY 區隔** —
# STT / LLM 是不同 API,不要共用同一支 key。
# GEMINI_API_KEY=AIzaSyXxxxxx

# ─── Listen 設定(可選) ────────────────────────────────────────────────────
# ORION_MODEL_PROXY_HOST=127.0.0.1       # 對外服改 0.0.0.0
# ORION_MODEL_PROXY_PORT=9090

# ─── Admin 認證(Phase 32 後必設,否則 admin endpoints 全 503) ─────────────
# Bearer token 給 admin REST(/admin/*)+ Web UI(/admin/ui/*)用。
# 跟「user 的 API key」分流:user key 走 DB 查(`sk-orion-<env>-...` 格式),
# admin 走這個 env 比對。產生方式:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ORION_MODEL_PROXY_ADMIN_KEY=
#
# 註:Phase 31-X 用的 `ORION_MODEL_PROXY_KEY`(單 token mode)已在 Phase 32
# 移除。client 端 token 由 admin 透過 UI / REST 為每 user 生成。
