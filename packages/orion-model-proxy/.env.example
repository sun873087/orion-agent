# orion-model-proxy — 只給跑 `make dev-model-proxy` 那台機看。
# Client(CLI / Chat / Cowork)不必看這份。
#
# 複製成 `.env`,填 upstream key:
#   cp packages/orion-model-proxy/.env.example packages/orion-model-proxy/.env

# ─── Upstream provider keys(必要) ─────────────────────────────────────────
# Proxy 收到 client request → 用這裡的真 key 覆寫 header 後 forward 到上游。
# 只設你會用的 provider。

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# ─── Listen 設定(可選) ────────────────────────────────────────────────────
# ORION_MODEL_PROXY_HOST=127.0.0.1       # 對外服改 0.0.0.0
# ORION_MODEL_PROXY_PORT=9090

# ─── 認證(可選但 production 強烈建議) ─────────────────────────────────────
# 設了 → request 必須帶 `Authorization: Bearer <same-value>`,沒帶 / 不對 403。
# 沒設 → 不認證(只給本機 dev 用,**不要這樣對外開**)。
# 產生方式:`uuidgen` 或 `python -c "import secrets; print(secrets.token_urlsafe(32))"`
# ORION_MODEL_PROXY_KEY=
