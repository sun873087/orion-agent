# 各子專案有自己的 .gitignore(api/.gitignore 等)— 此處只處理 repo 根。

# Python(workspace-wide,Phase 30 之後 packages/ 跟 apps/ 也要 cover)
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/

# Virtual env(workspace 共用 root .venv)
.venv/

# Node(npm workspaces hoist 到 root)
node_modules/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.playwright-mcp/

# 防呆:任何位置出現的 env 檔絕對不 commit
.env
.env.local
*.env

orion.db

# Phase 32 model-proxy:預設 SQLite at packages/orion-model-proxy/data/proxy.db
packages/orion-model-proxy/data/
