# Copy to .env and fill in your keys.
# Only set the providers you intend to use.

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# Optional: override base URLs (e.g. proxy / Bedrock / Together AI)
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama 相關 — 全部都是「可選」
# 如果 Ollama 在本機預設 port(localhost:11434),完全不用設,留空即可
# OLLAMA_HOST=localhost:11434

# Optional: global cap on max output tokens per assistant turn.
# Each model in models.json has its own max_output_tokens — leave this unset
# to use the per-model value. Set this only if you want a project-wide cap;
# the lower of (env, model max) wins (avoids 422 from APIs).
# ORION_MAX_TOKENS_PER_TURN=32768

# Optional: override the path to the model catalog JSON.
# Default: packaged src/orion_agent/llm/models.json (bundled with the wheel).
# Edit that file to add / remove / reprice models, then restart the server.
# ORION_MODELS_FILE=/path/to/custom-models.json

# ─── Prompt cache TTL (Anthropic only) ─────────────────────────────────────
# Three independent cache layers, each with its own ephemeral TTL.
# Anthropic charges 1.25× input tokens for 5m writes, 2× for 1h writes,
# but reads are always 0.1× (regardless of TTL).
#
# Defaults bias 1h for the stable system layers because static / session-
# stable content typically spans well past 5 minutes (multi-turn chats with
# idle gaps, cross-session reuse). Messages stay 5m because each turn writes
# the latest breakpoint anyway.
#
# Valid values: "5m" or "1h". Invalid values silently fall back to default.
# ORION_CACHE_TTL_STATIC=1h     # 7-段 static system prompt
# ORION_CACHE_TTL_SESSION=1h    # session-stable dynamic block (instructions,
#                               # MCP, language, output_style, etc.)
# ORION_CACHE_TTL_MESSAGES=5m   # rolling message-history breakpoints

# ─── WebFetchTool URL cache (Phase 18) ─────────────────────────────────────
# Per-session in-memory cache:同一 conversation 內反覆 fetch 同 URL 直接走
# cache(命中時模型看到的標題會加 "[cached]")。max 100 entries / session,
# 純記憶體,session 結束自動釋放。
# Seconds(整數或浮點)。預設 300(5 min)。"0" = 不啟用 TTL 失效(永遠新鮮直
# 到 LRU 踢掉);非數字 fallback 預設。
# ORION_WEBFETCH_TTL_SECONDS=300

# ─── File history snapshot cap (Phase 19) ──────────────────────────────────
# Edit / Write 工具寫檔前會快照舊內容到
# ~/.orion/sessions/<sid>/file-history/<hash>.snap(undo / 審計用)。同 hash
# 自動 dedupe,但不同內容無上限。長 session 反覆編輯多檔可能累積上千個。
# 此 env 設每 session 的 snapshot 數上限(以 mtime LRU 砍最舊);整數,預設
# 100。非正整數 / 非數字 fallback 預設。
# ORION_FILE_HISTORY_MAX_SNAPSHOTS=100

# ─── Memory relevance ranker ───────────────────────────────────────────────
# 每輪對話從 ~/.orion/users/<id>/memory 挑相關 memory 注入 system prompt。
#
# Modes:
#   heuristic (default) — bag-of-words 關鍵字重疊,零 LLM 成本,延遲 <1ms
#   llm                  — 送 memory descriptions + 最近 user 訊息給 LLM 評分,
#                          較準但每輪要呼叫一次模型
# ORION_MEMORY_RANKER=heuristic
#
# LLM ranker 預設用 Anthropic Haiku 4.5(跟主對話 model 解耦)— ranker 是輕任務,
# Haiku 比 Sonnet 便宜 3×、比 Opus 便宜 15×。建構失敗 / 沒 API key → 自動 fallback
# heuristic。可覆寫 model id;provider 從 models.json 自動偵測,所以 OpenAI 模型也
# 行(例: gpt-5-mini)。未知 model id 會 log warning 並退回 Haiku 4.5。
# ORION_MEMORY_RANKER_MODEL=claude-haiku-4-5

# Optional: SerpAPI key — enables the WebSearch tool (Google search results).
# Get a key at https://serpapi.com/manage-api-key. Without this, WebSearch
# returns a clear error and the model falls back to WebFetch on known URLs.
# SERPAPI_API_KEY=

# ─── Persistence ────────────────────────────────────────────────────────────

# Without ORION_DB_URL the server runs in in-memory mode — sessions, auth,
# and /me/settings all reset on restart. For real use point at SQLite or
# Postgres. SQLite file path:
# ORION_DB_URL=sqlite+aiosqlite:///./orion.db
# Postgres:
# ORION_DB_URL=postgresql+asyncpg://user:pass@localhost/orion

# Optional: secret for signing JWT auth tokens. A random default is generated
# at startup if unset — fine for dev, but invalidates all tokens on restart.
# Set a stable random string for any deployment users will log in to.
# ORION_JWT_SECRET=change-me-to-a-long-random-string

# ─── OAuth providers (Settings → Connections, Phase 25) ─────────────────────
# Each provider's Connect button is disabled until both vars are set.
# Register an OAuth app on the provider's side and use callback URL
#   http://localhost:8000/oauth/callback   (production: your https origin)

# GitHub — https://github.com/settings/developers → New OAuth App
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Linear — https://linear.app/settings/api/applications → New
# LINEAR_OAUTH_CLIENT_ID=
# LINEAR_OAUTH_CLIENT_SECRET=

# Google — https://console.cloud.google.com → APIs & Services → Credentials
# → Create OAuth client ID (Web application)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Microsoft — https://portal.azure.com → Microsoft Entra ID → App
# registrations. Client secret value only shown once at creation — copy then.
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=

# ─── Token storage (advanced) ───────────────────────────────────────────────

# By default OAuth / API-key tokens go into your OS credential store
# (macOS Keychain, Windows Credential Manager, Linux Secret Service via
# D-Bus). On Linux servers / Docker / CI without a keychain daemon, the
# code automatically falls back to ~/.orion/secrets.enc (Fernet-encrypted).
# Force the file backend by uncommenting:
# ORION_DISABLE_KEYCHAIN=1
# In production, generate a master key and inject from your secrets
# manager rather than letting it auto-generate to ~/.orion/.master.key:
#   uv run python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# ORION_MASTER_KEY=
